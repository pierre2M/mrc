# Copier ce fichier en .env et remplir les valeurs
# NE PAS commiter le .env (il est dans .gitignore)

# API Anthropic (Sprint 2 — démonstrateur Usage 1)
ANTHROPIC_API_KEY=

# Quota journalier (HMAC-SHA256 sur cookie signé) — générer avec: openssl rand -hex 32
QUOTA_SECRET=

# Cloudflare Turnstile — protection anti-bot
# Obtenir sur https://dash.cloudflare.com/ > Turnstile
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

# Rate limiting (optionnel, Sprint 2)
# MAX_REQUESTS_PER_MINUTE=20

# Analytics (Sprint 4 — Plausible)
# PUBLIC_PLAUSIBLE_DOMAIN=registre-communalite.org
